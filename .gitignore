# Default python.gitignore file
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
pip-wheel-metadata/
share/python-wheels/

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
Pipfile.lock

# poetry
.poetry/
poetry.lock

# PEP 582; used by e.g. pythonlocal
__pypackages__/

# Celery beat schedule file
celerybeat-schedule

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db

# Notebook checkpoints
.ipynb_checkpoints

# Coverage and profiling
coverage/

# Optional: virtual environment created by venv in project root
.venv/

# Claude Code
.claude/worktrees/
.claude/settings.local.json
.claude/user-team-info.json
.claude/tasks/
CLAUDE.local.md

# End of file

# custom additions - always keep this section at the end of the file and retain
# when updating or changing the .gitignore file.
# for some reason claude output has these junk nul files that cause problems with git, so we ignore them here.
nul
null
# general scratchpad file for 1-off notes and instructions that don't need to be committed to git
instructions-scratchpad.txt
# exported Teams chat data (contains media and conversation content)
exports/
# extracted PST email data
extracted_emails/
# MSAL token cache for device code flow (contains refresh tokens)
.token_cache.bin